# Streamlit secrets template — copy this file to `.streamlit/secrets.toml`
# and fill in your real key, then restart the app:
#
#     cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#     # edit .streamlit/secrets.toml, paste your key, save
#
# `.streamlit/secrets.toml` is gitignored, so your real key never lands in
# git. The Ask page reads this value via st.secrets and skips the in-page
# key prompt when it's set.
#
# ON STREAMLIT CLOUD: do NOT upload this file. Instead paste the same line
# into the app's dashboard under Manage app -> Settings -> Secrets.

# Your Anthropic API key (get one at https://console.anthropic.com/).
ANTHROPIC_API_KEY = "sk-ant-REPLACE-WITH-YOUR-KEY"

# To change the model the Ask page uses (defaults to claude-opus-4-8), set the
# ANTHROPIC_MODEL *environment variable* — it is not read from this secrets
# file.
